# Base de datos
DB_HOST=localhost
DB_PORT=5432
DB_NAME=docurural_db
DB_USER=docurural
DB_PASSWORD=

# JWT (obligatorio en prod; generar secret de >=32 bytes aleatorios)
JWT_SECRET=
JWT_EXPIRATION_MS=1800000
JWT_ISSUER=docurural

# Admin inicial (solo se usa en primer arranque)
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=

# Perfil Spring
SPRING_PROFILES_ACTIVE=dev
