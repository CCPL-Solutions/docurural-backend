# Base de datos
DB_HOST=localhost
DB_PORT=5432
DB_NAME=docurural_db
DB_USER=docurural
DB_PASSWORD=

# JWT (generar secret de >=32 bytes aleatorios)
JWT_SECRET=
JWT_EXPIRATION_MS=1800000
JWT_ISSUER=docurural

# Admin inicial (solo se usa en primer arranque; operación idempotente)
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=

# Seguridad
DOCURURAL_BCRYPT_STRENGTH=12

# Almacenamiento de archivos (todos los entornos usan S3)
DOCURURAL_STORAGE_PROVIDER=s3
DOCURURAL_STORAGE_BASE_PATH=./uploads/documents
DOCURURAL_STORAGE_MAX_FILE_SIZE=10MB
DOCURURAL_STORAGE_MAX_REQUEST_SIZE=55MB
DOCURURAL_STORAGE_S3_BUCKET=
AWS_REGION=us-east-1
DOCURURAL_STORAGE_S3_KEY_PREFIX=documents

# AWS Parameter Store
# dev no importa Parameter Store; usa las variables de entorno de arriba.
# qa y prod tienen el import fijo en su application-<entorno>.yaml.

# Perfil Spring
SPRING_PROFILES_ACTIVE=dev

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200
